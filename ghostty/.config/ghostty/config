# Ghostty Configuration
# Main configuration file

# Font configuration
font-family = "SF Mono"
font-size = 16

# Window settings
window-padding-x = 10
window-padding-y = 10
window-decoration = true
macos-titlebar-style = hidden
macos-window-buttons = hidden
macos-non-native-fullscreen = true
macos-window-shadow = false

# Performance
window-vsync = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Shell
shell-integration = detect
shell-integration-features = cursor,sudo,title
# Automatically fix the terminal info on every new server
shell-integration-features = ssh-terminfo

# Automatically forward your SSH environment
shell-integration-features = ssh-env

# Theme — active palette is selected by themes/theme-current.conf
# (currently Dunder Mifflin; switch there to flexoki/dracula/nord/etc).
config-file = themes/theme-current.conf

# Clipboard
clipboard-read = allow
clipboard-write = allow
# Espanso on Linux Wayland pastes via Shift+Insert by default.
# Use the clipboard for that chord instead of the primary selection.
keybind = shift+insert=paste_from_clipboard

# Mouse
mouse-hide-while-typing = true

# Background
background-opacity = 1.0

# Terminal features
confirm-close-surface = false
quit-after-last-window-closed = true
